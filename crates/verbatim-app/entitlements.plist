<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Hardened-runtime entitlement for mic capture (cpal). Accessibility
	     text injection is granted at runtime via TCC, not an entitlement. -->
	<key>com.apple.security.device.audio-input</key>
	<true/>
</dict>
</plist>
