{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Verbatim",
  "version": "0.1.0",
  "identifier": "app.verbatim.dictation",
  "build": {
    "frontendDist": "../../ui/dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Verbatim",
        "width": 520,
        "height": 400
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
