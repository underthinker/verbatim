# OS
.DS_Store

# Editors
.idea/
.vscode/
*.swp

# Rust (future)
target/

# Node
node_modules/
dist/
# The Tauri context embeds ui/dist at compile time; keep the directory present
# so a Rust-only `cargo build` works before the frontend has been built.
!ui/dist/
ui/dist/*
!ui/dist/.gitkeep

# Models and audio samples are never committed
*.gguf
*.ggml
*.bin
*.onnx
*.wav
*.mp3
*.m4a

# Spike scratch output
spikes/**/out/

# Tooling caches
.impeccable/

# Tauri build-time codegen
crates/verbatim-app/gen/

# Keep the benchmark speech fixture tracked despite the *.wav rule above.
!benches/fixtures/jfk.wav
